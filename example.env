# =============================================================================
# Bookmark - Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your deployment
#
# For docker-compose.yml (build from source with Traefik):
#   docker compose up -d
#
# For docker-compose.prod.yml (pre-built images):
#   docker compose -f docker-compose.prod.yml up -d

# =============================================================================
# Required Configuration
# =============================================================================

# The public URL where the application is accessible
# Used for auth callbacks and CORS configuration
PUBLIC_URL=https://bookmark.example.com

# Authentication secret - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-secure-secret

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=bookmark

# =============================================================================
# Data Paths
# =============================================================================
# Base path for application data (postgres, covers, cache)
# For docker-compose.prod.yml, defaults to ./data if not set
DATA_PATH=./data

# Mount paths to your audiobook, ebook, and comic libraries
# These are read-only mounts - the app won't modify your files
AUDIOBOOK_LIBRARY_PATH=/path/to/your/audiobooks
EBOOK_LIBRARY_PATH=/path/to/your/ebooks
COMIC_LIBRARY_PATH=/path/to/your/comics

# =============================================================================
# OIDC / SSO Configuration (optional)
# =============================================================================
# Enable OIDC authentication (requires restart to change)
OIDC_ENABLED=false

# Your identity provider's issuer URL (e.g., Authentik, Keycloak, Authelia)
# Example: https://auth.example.com/application/o/bookmark/
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# =============================================================================
# Content Requests / Tracker Client (optional)
# =============================================================================
# Enable users to search and request content from a torrent tracker.
# Requires a running tracker client API that exposes the gateway endpoints
# (/search, /download, /torrents, /image).
TRACKER_CLIENT_URL=
TRACKER_CLIENT_API_KEY=

# =============================================================================
# Production Image Configuration (docker-compose.prod.yml only)
# =============================================================================
# Container registry and image settings
# REGISTRY=ghcr.io
# IMAGE_PREFIX=your-org/bookmark
# IMAGE_TAG=latest

# Port to expose the frontend on (default: 3001)
# PORT=3001

# =============================================================================
# Traefik Configuration (docker-compose.yml only)
# =============================================================================
# Only needed if using docker-compose.yml with Traefik reverse proxy
# Hostname for Traefik routing (should match PUBLIC_URL without protocol)
# TRAEFIK_HOST=bookmark.example.com
