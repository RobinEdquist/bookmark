# =============================================================================
# Bookmark - Docker Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your deployment

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=bookmark

# =============================================================================
# Authentication (REQUIRED)
# =============================================================================
# Generate a secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-secure-secret

# URL where the backend API is accessible (used internally)
BETTER_AUTH_URL=http://backend:3000

# =============================================================================
# URLs (adjust for your deployment)
# =============================================================================
# Frontend URL - used for CORS configuration
# Set to your actual domain in production (e.g., https://bookmark.example.com)
UI_URL=http://localhost:3001

# Public API URL - used by the browser to connect to backend
# Must be accessible from the user's browser
# For local: http://localhost:3000
# For production behind reverse proxy: https://bookmark.example.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# =============================================================================
# Port Configuration (optional)
# =============================================================================
BACKEND_PORT=3000
FRONTEND_PORT=3001

# =============================================================================
# Library Paths
# =============================================================================
# Mount paths to your audiobook and ebook libraries
# These are read-only mounts - the app won't modify your files
AUDIOBOOK_LIBRARY_PATH=/path/to/your/audiobooks
EBOOK_LIBRARY_PATH=/path/to/your/ebooks

# =============================================================================
# OIDC / SSO Configuration (optional)
# =============================================================================
# Enable OIDC authentication (requires restart to change)
OIDC_ENABLED=false

# Your identity provider's issuer URL (e.g., Authentik, Keycloak, Authelia)
# Example: https://auth.example.com/application/o/bookmark/
OIDC_ISSUER_URL=

# Client credentials from your identity provider
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# =============================================================================
# Traefik Configuration (optional)
# =============================================================================
# Hostname for Traefik routing (used in Host rule)
# The compose file connects to an external 'proxy' network for Traefik
TRAEFIK_HOST=bookmark.test.example.com

# =============================================================================
# Production Notes
# =============================================================================
# 1. Always change default passwords and secrets before deploying
# 2. The compose file integrates with an external Traefik proxy network
# 3. Set UI_URL and NEXT_PUBLIC_API_URL to match your TRAEFIK_HOST with https://
# 4. Back up the postgres_data and app_data Docker volumes regularly
# 5. Library paths are mounted read-only for safety
# 6. The proxy network must exist: docker network create proxy
