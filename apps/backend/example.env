# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookmark

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-here

# Frontend URL
UI_URL=http://localhost:3001

# OIDC Configuration (optional)
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://auth.example.com
OIDC_CLIENT_ID=bookmark
OIDC_CLIENT_SECRET=your-client-secret

# Content Requests / Tracker Client (optional)
# Enable users to search and request content from a torrent tracker.
TRACKER_CLIENT_URL=http://localhost:8080
TRACKER_CLIENT_API_KEY=your-tracker-client-api-key
