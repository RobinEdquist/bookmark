{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testTimeout": 30000,
  "globalSetup": "<rootDir>/setup/globalSetup.ts",
  "globalTeardown": "<rootDir>/setup/globalTeardown.ts"
}
